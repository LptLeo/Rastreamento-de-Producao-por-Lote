# Configurações do Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=senha_segura_123
DB_NAME=lotepim

# Configurações de Autenticação
JWT_SECRET=substitua_por_uma_chave_secreta_longa_e_aleatoria
JWT_REFRESH_SECRET=substitua_por_outra_chave_secreta_diferente_da_primeira

# Configurações da API (Opcional)
PORT=3000
NODE_ENV=development

# --- Configurações do Seed de Dados ---
# Total de lotes de produção a serem criados no histórico
SEED_TOTAL_LOTES_PRODUCAO=180
# Intervalo de meses para distribuir os lotes passados
SEED_MESES_HISTORICO=3
# Taxa base de reprovação (ex: 10%)
SEED_REPROVACAO_BASE=10
# Variação da taxa (+/-) para gerar aleatoriedade (ex: se base=10 e var=10, reprovação vai de 0% a 20%)
SEED_REPROVACAO_VARIACAO=10
# Carga extra de insumos em estoque acima do necessário para produzir todos os lotes (ex: 35%)
SEED_INSUMO_SURPLUS_PCT=35

# Credenciais para o Seed Inicial
SEED_USER_EMAIL=gestor@lotepim.com
SEED_USER_PASSWORD=senha123

# Configuração de Produção (Demo)
TEMPO_PRODUCAO_MINUTOS=2
