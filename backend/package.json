{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "db:up": "sudo docker compose up -d",
    "db:down": "sudo docker compose down",
    "db:reset": "sudo docker compose down -v && sudo docker compose up -d",
    "dev": "tsx watch src/server.ts",
    "seed": "tsx src/config/seed.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --testPathPatterns=src/services/__tests__",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules cross-env NODE_ENV=test jest --testPathPatterns=src/routes/__tests__ --runInBand --forceExit --detectOpenHandles",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
